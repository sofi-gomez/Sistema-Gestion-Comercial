spring.application.name=Sistema-Gestion

# ⚠️ Copiar este archivo como application.properties y completar con valores reales
spring.datasource.url=jdbc:mysql://localhost:3306/gestion_db?useSSL=false&serverTimezone=UTC
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

spring.jpa.show-sql=false
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false

# Seguridad
app.jwt.secret=YOUR_JWT_SECRET_KEY_MIN_32_CHARS

server.port=8080
spring.jackson.serialization.fail-on-empty-beans=false

spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.deserialization.fail-on-unknown-properties=false

# Inicialización diferida: acelera el arranque cargando beans solo cuando se necesitan
spring.main.lazy-initialization=true
